// Prisma Schema для DentLux
// PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  ARRIVED
  VISITED
  MISSED
  COMPLETED
  DONE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  SALARY
  EQUIPMENT
  RENT
  UTILITIES
  SUPPLIES
  OTHER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(CLIENT)
  fullName     String    @map("full_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  clientAppointments Appointment[] @relation("ClientAppointments")
  doctorAppointments Appointment[] @relation("DoctorAppointments")
  clientMedicalRecords MedicalRecord[] @relation("ClientMedicalRecords")
  doctorMedicalRecords MedicalRecord[] @relation("DoctorMedicalRecords")
  clientReviews      Review[] @relation("ClientReviews")
  doctorReviews      Review[] @relation("DoctorReviews")
  auditLogs          AuditLog[] @relation("UserAuditLogs")
  doctor            Doctor?
  refunds           Refund[]
  expenses          Expense[]
  processedRefunds  Refund[]       @relation("ProcessedByUser")
  passwordResetTokens PasswordResetToken[]
  clientBlocks      ClientBlock[] @relation("ClientBlocks")
  blockedClients    ClientBlock[] @relation("BlockedByUser")
  unblockedClients  ClientBlock[] @relation("UnblockedByUser")

  @@map("users")
  @@index([email])
}

model Doctor {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  specialization   String?
  experienceYears  Int?     @map("experience_years")
  workSchedule     String?  @map("work_schedule") // JSON stored as string
  isBlocked        Boolean  @default(false) @map("is_blocked")
  blockedUntil     DateTime? @map("blocked_until")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctors")
}

model Service {
  id             String   @id @default(uuid())
  name           String
  description    String?  @db.Text
  durationMinutes Int     @map("duration_minutes")
  price          Decimal  @db.Decimal(10, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  appointments Appointment[]
  reviews      Review[]

  @@map("services")
}

model Appointment {
  id             String           @id @default(uuid())
  clientId       String           @map("client_id")
  doctorId       String           @map("doctor_id")
  serviceId      String           @map("service_id")
  appointmentDate DateTime        @map("appointment_date") @db.Date
  appointmentTime DateTime        @map("appointment_time") @db.Time
  status         AppointmentStatus @default(PENDING)
  notes          String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  client User    @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  doctor User    @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  payment Payment?
  medicalRecord MedicalRecord?
  review Review?
  clientBlocks ClientBlock[]

  @@map("appointments")
  @@index([clientId])
  @@index([doctorId])
  @@index([appointmentDate, appointmentTime])
}

model Payment {
  id                   String       @id @default(uuid())
  appointmentId        String       @unique @map("appointment_id")
  amount               Decimal      @db.Decimal(10, 2)
  status               PaymentStatus @default(PENDING)
  paymentMethod        PaymentMethod @default(CASH) @map("payment_method")
  receiptPdfPath       String?      @map("receipt_pdf_path")
  paymentDate          DateTime     @default(now()) @map("payment_date")
  gatewayTransactionId String?      @map("gateway_transaction_id")
  gatewayType          String?      @map("gateway_type")
  paymentUrl           String?      @db.Text @map("payment_url")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  refunds     Refund[]

  @@map("payments")
  @@index([appointmentId])
  @@index([gatewayTransactionId])
  @@index([status])
}

model Refund {
  id          String       @id @default(uuid())
  paymentId   String       @map("payment_id")
  clientId    String       @map("client_id")
  amount      Decimal      @db.Decimal(10, 2)
  reason      String?      @db.Text
  status      RefundStatus @default(PENDING)
  adminNotes  String?      @map("admin_notes") @db.Text
  processedBy String?      @map("processed_by")
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  client      User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  processedByUser User? @relation("ProcessedByUser", fields: [processedBy], references: [id], onDelete: SetNull)

  @@map("refunds")
  @@index([paymentId])
  @@index([clientId])
}

model Expense {
  id          String         @id @default(uuid())
  category    ExpenseCategory
  amount      Decimal        @db.Decimal(10, 2)
  description String?        @db.Text
  expenseDate DateTime       @map("expense_date") @db.Date
  createdBy   String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@map("expenses")
  @@index([expenseDate])
  @@index([category])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
  @@index([email])
  @@index([isRead])
  @@index([createdAt])
}

model MedicalRecord {
  id             String   @id @default(uuid())
  appointmentId  String   @unique @map("appointment_id")
  clientId       String   @map("client_id")
  doctorId       String   @map("doctor_id")
  diagnosis      String?  @db.Text
  treatment      String?  @db.Text
  notes          String?  @db.Text
  prescriptions  String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      User        @relation("ClientMedicalRecords", fields: [clientId], references: [id], onDelete: Cascade)
  doctor      User        @relation("DoctorMedicalRecords", fields: [doctorId], references: [id], onDelete: Restrict)

  @@map("medical_records")
  @@index([clientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(uuid())
  appointmentId String @unique @map("appointment_id")
  clientId    String   @map("client_id")
  doctorId    String?  @map("doctor_id")
  serviceId   String?  @map("service_id")
  rating      Int      // 1-5
  comment     String?  @db.Text
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      User        @relation("ClientReviews", fields: [clientId], references: [id], onDelete: Cascade)
  doctor      User?       @relation("DoctorReviews", fields: [doctorId], references: [id], onDelete: SetNull)
  service     Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@map("reviews")
  @@index([clientId])
  @@index([doctorId])
  @@index([serviceId])
  @@index([appointmentId])
  @@index([rating])
  @@index([isApproved])
  @@index([createdAt])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  CANCEL
}

model AuditLog {
  id        String     @id @default(uuid())
  userId    String?    @map("user_id")
  action    AuditAction
  entityType String    @map("entity_type") // 'User', 'Appointment', 'Payment', etc.
  entityId  String?    @map("entity_id")
  changes   String?    @db.Text // JSON string with old/new values
  ipAddress String?    @map("ip_address")
  userAgent String?    @map("user_agent") @db.Text
  createdAt DateTime   @default(now()) @map("created_at")

  user User? @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model ClientBlock {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  blockedBy     String   @map("blocked_by")
  reason        String?  @db.Text
  appointmentId String?  @map("appointment_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  unblockedAt   DateTime? @map("unblocked_at")
  unblockedBy   String?  @map("unblocked_by")

  client      User        @relation("ClientBlocks", fields: [clientId], references: [id], onDelete: Cascade)
  blockedByUser User      @relation("BlockedByUser", fields: [blockedBy], references: [id], onDelete: Restrict)
  unblockedByUser User?   @relation("UnblockedByUser", fields: [unblockedBy], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("client_blocks")
  @@index([clientId])
  @@index([isActive])
  @@index([appointmentId])
  @@index([createdAt])
}

